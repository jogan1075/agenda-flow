        {
          "name": "Send Location Utility",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/whatsapp-bot/send-location/{{businessId}}?to={{testPhone}}"
          }
        },
        {
          "name": "Meta Verify Webhook",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/whatsapp-bot/webhook/meta?hub.mode=subscribe&hub.verify_token=TOKEN&hub.challenge=12345"
          }
        },
        {
          "name": "Webhook Meta - Text Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/whatsapp-bot/webhook/meta?businessId={{businessId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entry\": [{\n    \"changes\": [{\n      \"value\": {\n        \"messages\": [{\n          \"from\": \"56911112222\",\n          \"text\": { \"body\": \"menu\" }\n        }]\n      }\n    }]\n  }]\n}"
